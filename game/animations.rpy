### Animations and Transitions

# Tried a fancier zoom in, doesn't look that nice
transform pan_zoom_in:
    zoom 1.0
    xalign 0.5
    yalign 0.5
    linear 1.5 zoom 2.0 xalign 0.5 yalign 0.6


# Custom character positions, the default ones are bad
transform left_pos:
    xalign 0.2
    yalign 1.0

transform right_pos:
    xalign 0.8
    yalign 1.0